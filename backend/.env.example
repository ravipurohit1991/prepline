# Prepline backend configuration
# Copy this file to .env and adjust values, or export PREPLINE_* variables directly.

# SQLite database URL. Relative paths are resolved from the backend/ directory.
PREPLINE_DATABASE_URL=sqlite:///./prepline.db

# Seed the demo "Sunday Roast for Four" meal plan when the database is empty.
PREPLINE_SEED_ON_EMPTY=true

# CORS origins allowed for API + WebSocket requests.
# The Vite dev server runs on port 5173 by default.
PREPLINE_CORS_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173"]
